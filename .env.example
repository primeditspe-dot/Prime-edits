# Server Configuration
PORT=5000

# Firebase Service Account JSON (Stringified)
# You can generate a private key file for your service account from the Firebase console:
# Project Settings > Service Accounts > Generate new private key.
# Convert the JSON file into a single line string to paste here, or set GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternatively, set the path to your service account json file:
GOOGLE_APPLICATION_CREDENTIALS=

# Cloudinary Credentials
# Find these on your Cloudinary Dashboard under API Keys:
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
